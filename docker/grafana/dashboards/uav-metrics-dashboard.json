{
  "dashboard": {
    "title": "UAV Agent 飞行控制平台",
    "uid": "uav-agent-main",
    "timezone": "browser",
    "tags": ["uav", "spring-boot", "agent", "drone"],
    "refresh": "10s",
    "panels": [
      {
        "title": "LLM Agent 调用 QPS",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [{"expr": "rate(uav_agent_calls_total[1m])", "legendFormat": "Agent QPS"}],
        "yaxes": [{"format": "short", "label": "calls/s"}]
      },
      {
        "title": "Agent 调用延迟 P95",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [{"expr": "uav_agent_call_duration_seconds{quantile=\"0.95\"}", "legendFormat": "P95 延迟"}],
        "yaxes": [{"format": "s", "label": "seconds"}]
      },
      {
        "title": "飞控指令分布",
        "type": "piechart",
        "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
        "targets": [{"expr": "rate(uav_drone_commands_total[5m])", "legendFormat": "{{command}}"}]
      },
      {
        "title": "遥测推送频率",
        "type": "graph",
        "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
        "targets": [{"expr": "rate(uav_telemetry_push_total[1m])", "legendFormat": "推送/秒"}],
        "yaxes": [{"format": "short"}]
      },
      {
        "title": "任务状态变更",
        "type": "stat",
        "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
        "targets": [{"expr": "rate(uav_mission_state_changes_total[5m])", "legendFormat": "任务变更速率"}]
      },
      {
        "title": "异常检测触发",
        "type": "stat",
        "gridPos": {"x": 0, "y": 16, "w": 8, "h": 6},
        "targets": [{"expr": "uav_anomaly_detected_total", "legendFormat": "异常总数"}],
        "thresholds": [{"value": 0, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 5, "color": "red"}]
      },
      {
        "title": "JVM 内存使用率",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 16, "w": 8, "h": 6},
        "targets": [{"expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"}) * 100", "legendFormat": "Heap 使用率"}],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
      },
      {
        "title": "HTTP 请求 QPS",
        "type": "graph",
        "gridPos": {"x": 16, "y": 16, "w": 8, "h": 6},
        "targets": [{"expr": "rate(http_server_requests_seconds_count[1m])", "legendFormat": "HTTP QPS"}]
      }
    ],
    "schemaVersion": 38,
    "version": 1
  }
}
